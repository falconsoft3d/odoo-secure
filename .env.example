# ── Obligatorias ─────────────────────────────────────────────────────────────
# Genera una clave segura: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambia-esto-por-una-clave-segura

# ── Entorno ───────────────────────────────────────────────────────────────────
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com,IP_DEL_SERVIDOR

# ── Base de datos ─────────────────────────────────────────────────────────────
# Ruta dentro del contenedor (mapeada al volumen odoo_secure_data)
DB_PATH=/app/data/db.sqlite3

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Pon 'true' si usas nginx con SSL por delante del contenedor
HTTPS=false

# ── Docker socket GID ─────────────────────────────────────────────────────────
# Obtén el GID con: getent group docker | cut -d: -f3
DOCKER_GID=999
